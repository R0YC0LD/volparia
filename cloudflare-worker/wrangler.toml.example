# Bu dosyayı "wrangler.toml" adıyla kopyalayın ve database_id alanını doldurun.
name = "volparia-api"
main = "src/index.js"
compatibility_date = "2026-01-01"

[[d1_databases]]
binding = "DB"
database_name = "volparia-db"
database_id = "BURAYA-D1-DATABASE-ID-GELECEK"

[vars]
# Kart ödemesi sonrası müşterinin geri yönlendirileceği mağaza adresi
STOREFRONT_URL = "https://r0yc0ld.github.io/volparia/"
# Virgülle ayrılmış CORS izin listesi. Özel alan adı kullanırsanız onu da ekleyin.
ALLOWED_ORIGINS = "https://r0yc0ld.github.io"

# Gizli değerler dosyaya YAZILMAZ, şu komutlarla eklenir:
#   wrangler secret put ADMIN_PASSWORD
#   wrangler secret put SESSION_SECRET
# ADMIN_PASSWORD en az 12, SESSION_SECRET en az 32 karakter olmalıdır.
# İsteğe bağlı: ADMIN_USERNAME (varsayılan: admin; değiştirilmesi önerilir)
